// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
    "name": "Scaler-Dev",
    // More info: https://containers.dev/guide/dockerfile
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.black-formatter",
                "ms-python.flake8",
                "ms-python.isort",
                "ms-python.mypy-type-checker",
                "ms-python.python",
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools"
            ],
            "settings": {
                "[python]": {
                    "editor.defaultFormatter": "ms-python.black-formatter",
                    "editor.formatOnSave": true,
                    "editor.codeActionsOnSave": {
                        "source.organizeImports": "explicit"
                    },
                    "editor.tabSize": 4,
                    "files.trimTrailingWhitespace": true
                },
                "black-formatter.args": ["-l", "120", "-C"],
                "isort.args": ["--profile", "black", "--line-length", "120"],
                "flake8.args": ["--max-line-length", "120", "--extend-ignore", "E203"],
                "cmake.configureOnOpen": false
            }
        }
    },
    // The wasm chain (emsdk, pyodide-build, wasm-target capnp/libuv) is baked
    // into /opt/scaler/ in the image. emsdk paths (EMSDK / emcc / emcmake /
    // bundled node) are exported by /etc/profile.d/emsdk.sh in the image; the
    // remaining vars wire pyodide-build's venv and the wasm capnp/libuv
    // install prefix into PATH and cmake the same way CI does.
    "containerEnv": {
        "PATH": "/opt/scaler/pyodide-venv/bin:${containerEnv:PATH}",
        "CapnProto_DIR": "/opt/scaler/wasm/install/lib/cmake/CapnProto",
        "CMAKE_PREFIX_PATH": "/opt/scaler/wasm/install"
    }
}
